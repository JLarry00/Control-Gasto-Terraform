# Copia a terraform.tfvars y rellena. terraform.tfvars no se sube a git.

project_id          = "laboratirio-devops-thinkia"
billing_account_id  = "012345-ABCDEF-678901"
region              = "europe-west1"
budget_amount       = 1
budget_currency     = "EUR"
budget_alert_thresholds = [1.0]

# Mapa: API id (Service Usage) -> ID de servicio de facturación (Billing).
# Obtener IDs en Billing > Informes o Catalog API. Un presupuesto por entrada.
api_to_billing_service_id = {
  "run.googleapis.com"        = "E2C7-4E94-8B22",
  "aiplatform.googleapis.com" = "2E3F-6D8A-1B4C",
  "bigquery.googleapis.com"   = "24E6-581D-38E5",
  "firebase.googleapis.com"   = "1A2B-3C4D-5E6F",
  "container.googleapis.com"  = "6F81-5844-456A"
}

# APIs que la función puede deshabilitar cuando su presupuesto se supere.
apis_to_control_on_budget_exceeded = [
  "run.googleapis.com",
  "aiplatform.googleapis.com",
  "bigquery.googleapis.com",
  "firebase.googleapis.com",
  "container.googleapis.com"
]
